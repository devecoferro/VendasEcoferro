APP_BASE_URL="https://vendas.ecoferro.com.br"
PORT="3000"
HOST="0.0.0.0"
DATA_DIR="./data"

# ─── Mercado Livre OAuth (obrigatório) ───────────────────────────────
# Obtenha em https://developers.mercadolivre.com.br/devcenter → sua app
ML_CLIENT_ID=""
ML_CLIENT_SECRET=""
VITE_ML_REDIRECT_URI="https://vendas.ecoferro.com.br/ml-callback"
VITE_API_PROXY_TARGET="http://localhost:3000"

# ─── Admin default (obrigatório) ─────────────────────────────────────
# Criado automaticamente no primeiro boot. MUDE a senha via UI depois
# do primeiro login; envira var só sincroniza no startup (não em requests).
APP_DEFAULT_ADMIN_USERNAME=""
APP_DEFAULT_ADMIN_PASSWORD=""
APP_IMPORTED_USER_PASSWORD=""
APP_SESSION_COOKIE_NAME="ecoferro_session"
APP_SESSION_TTL_DAYS="7"
HEALTHCHECK_BASE_URL="http://127.0.0.1:3000"
HEALTHCHECK_PING_URL=""
BACKUP_RUNTIME_DIR="./data/backups/runtime"
BACKUP_MIRROR_DIR=""
BACKUP_RETENTION_DAYS="14"
BACKUP_INCLUDE_PLAYWRIGHT_STATE="false"
SELLER_CENTER_CAPTURE_STORAGE_STATE_PATH="./data/playwright/private-seller-center.storage-state.json"
SELLER_CENTER_CAPTURE_SELECTED_TAB="TAB_TODAY"
SELLER_CENTER_CAPTURE_HEADLESS="false"
SELLER_CENTER_CAPTURE_LOGIN_TIMEOUT_MS="600000"
ECOFERRO_CAPTURE_BASE_URL="http://127.0.0.1:3000"
ECOFERRO_CAPTURE_USERNAME=""
ECOFERRO_CAPTURE_PASSWORD=""
ECOFERRO_CAPTURE_SESSION_COOKIE_NAME="ecoferro_session"
# ─── Obsidian (Local REST API plugin) ─────────────────────────────
# API Key gerada pelo plugin Local REST API no Obsidian
OBSIDIAN_API_KEY=""
# URL base da API (padrão HTTPS na porta 27124)
OBSIDIAN_BASE_URL="https://127.0.0.1:27124"

# Variaveis abaixo sao usadas apenas na migracao inicial do Supabase para o banco local da VPS.
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
